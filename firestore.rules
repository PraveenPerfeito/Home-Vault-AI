rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user may only read and write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Items are scoped to the owner's sub-collection.
      // The server enforces ownership — client-side userId checks are defence-in-depth only.
      match /items/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
