ios/
linux/
macos/
windows/
web/

# Flutter metadata
.metadata

# Kotlin DSL duplicates (project uses Groovy DSL)
android/app/build.gradle.kts
android/build.gradle.kts
android/settings.gradle.kts

# Android debug/profile source sets
android/app/src/debug/
android/app/src/profile/

# Environment secrets
.env
.env.local
